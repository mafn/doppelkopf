{
  "name": "doppelkopf",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <27",
    "npm": ">=11"
  },
  "scripts": {
    "predev": "node .scripts/sync-onnxruntime-vendor.mjs",
    "dev": "astro dev --host 127.0.0.1",
    "prebuild": "node .scripts/sync-onnxruntime-vendor.mjs",
    "build": "astro build",
    "prepreview": "node .scripts/sync-onnxruntime-vendor.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "check": "astro check",
    "test": "playwright test",
    "test:engine": "playwright test --config=playwright.unit.config.ts",
    "test:browser": "playwright test tests/doppelkopf-pages.spec.ts tests/onnxruntime-assets.spec.ts",
    "v3:check": "astro check",
    "v3:test": "playwright test --config=playwright.unit.config.ts tests/doppelkopf-v3-boundaries.spec.ts",
    "v3:astro:smoke": "astro --root tests/fixtures/astro-v3 --config astro.config.mjs build",
    "v3:test:complete": "npm run v3:test && npm run v3:astro:smoke",
    "v3:bench": "tsx .scripts/bench-v3.ts",
    "verify": "npm run format:check && npm run check && npm run build && npm run test:engine && npm run test:browser",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@fontsource-variable/space-grotesk": "^5.2.5",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^7.0.7",
    "onnxruntime-web": "^1.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "eslint": "^9.17.0",
    "eslint-plugin-package-json": "^0.23.0",
    "jsonc-eslint-parser": "^2.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "vite": "^8.1.4"
  },
  "overrides": {
    "lodash": "^4.17.23"
  }
}
