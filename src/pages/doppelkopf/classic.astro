---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ClassicMode from "../../components/doppelkopf/modes/Classic.astro";

const canonicalURL = new URL("/doppelkopf/classic/", Astro.site);
---

<BaseLayout
  title="Doppelkopf — Classic"
  description="Classic Doppelkopf table against three bots."
  renderH1={false}
  shellMode="immersive"
  canonicalURL={canonicalURL}
>
  <ClassicMode
    rulesetKind="standard"
    title="Doppelkopf — Classic"
    showLinks={false}
  />
</BaseLayout>
